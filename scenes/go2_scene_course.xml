<mujoco model="go2 scene course (5 waypoint, 3 obstacle)">
  <include file="go2_rangefinder.xml"/>

  <statistic center="1.5 1.5 0.2" extent="2.5"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="8 8" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="1.5 1.5 3" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="4 4 0.05" type="plane" material="groundplane"/>
    <!-- 3 obstacles, each on a leg between waypoints (0.6 m tall so the chest
         rangefinder detects them; 0.3x0.3 m footprint). Robot detours around. -->
    <geom name="obstacle1" pos="1.5 0.0 0.3" type="box" size="0.15 0.15 0.3" rgba="0.8 0.2 0.2 1"/>
    <geom name="obstacle2" pos="3.0 1.5 0.3" type="box" size="0.15 0.15 0.3" rgba="0.8 0.2 0.2 1"/>
    <geom name="obstacle3" pos="1.5 3.0 0.3" type="box" size="0.15 0.15 0.3" rgba="0.8 0.2 0.2 1"/>
  </worldbody>
</mujoco>